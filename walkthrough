#!/bin/bash

# Step 1: Install Java 21
sudo apt update -y
sudo apt install openjdk-21-jdk -y
java -version

# Step 2: Download & Setup Tomcat 9
cd /opt
sudo wget https://archive.apache.org/dist/tomcat/tomcat-9/v9.0.89/bin/apache-tomcat-9.0.89.tar.gz
sudo tar -xvzf apache-tomcat-9.0.89.tar.gz
sudo mv apache-tomcat-9.0.89 tomcat
sudo rm -f apache-tomcat-9.0.89.tar.gz

# Step 3: Set Permissions
sudo chmod +x /opt/tomcat/bin/*.sh

# Step 4: Allow Remote Access
sudo sed -i 's/<Valve/<!--<Valve/g' /opt/tomcat/webapps/host-manager/META-INF/context.xml
sudo sed -i 's/\/>$/\/>-->/g' /opt/tomcat/webapps/host-manager/META-INF/context.xml
sudo sed -i 's/<Valve/<!--<Valve/g' /opt/tomcat/webapps/manager/META-INF/context.xml
sudo sed -i 's/\/>$/\/>-->/g' /opt/tomcat/webapps/manager/META-INF/context.xml

# Step 5: Add Users
sudo tee /opt/tomcat/conf/tomcat-users.xml > /dev/null << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<tomcat-users>
  <role rolename="manager-gui"/>
  <role rolename="manager-script"/>
  <role rolename="manager-jmx"/>
  <role rolename="manager-status"/>
  <user username="admin"    password="admin"    roles="manager-gui,manager-script,manager-jmx,manager-status"/>
  <user username="deployer" password="deployer" roles="manager-script"/>
  <user username="tomcat"   password="s3cret"   roles="manager-gui"/>
</tomcat-users>
EOF

# Step 6: Change Port to 9000
sudo sed -i 's/port="8080"/port="9000"/' /opt/tomcat/conf/server.xml

# Step 7: Start Tomcat
sudo /opt/tomcat/bin/startup.sh

echo "=========================================="
echo " Tomcat URL : http://$(curl -s ifconfig.io):9000"
echo " Manager    : http://$(curl -s ifconfig.io):9000/manager"
echo " User       : admin / admin"
echo "=========================================="


