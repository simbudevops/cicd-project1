###Deploying machine for project using terraform###

terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

# Configure AWS Provider
provider "aws" {
  region = "ap-south-1" # Change region as required
}

resource "aws_security_group" "cicd_SG" {
  name        = "cicd_SG"
  description = "Allow inbound traffic"

  ingress = [
    for port in [22, 80, 443, 8080, 9000, 3000] : {
      description      = "Inbound Rules"
      from_port        = port
      to_port          = port
      protocol         = "tcp"
      cidr_blocks      = ["0.0.0.0/0"]
      ipv6_cidr_blocks = []
      prefix_list_ids  = []
      security_groups  = []
      self             = false
    }
  ]

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "cicd_SG"
  }
}

resource "aws_instance" "cicd_VM" {
  ami                    = "ami-0388e3ada3d9812da" # Change AMI as per region
  instance_type          = "m7i-flex.large"
  key_name               = "testing-1" # Change key name as per your setup
  vpc_security_group_ids = [aws_security_group.cicd_SG.id]
  user_data              = templatefile("./install.sh", {})

  tags = {
    Name = "cicd"
  }

  root_block_device {
    volume_size = 40
  }
}

output "public_ip" {
  value = aws_instance.cicd_VM.public_ip
}
