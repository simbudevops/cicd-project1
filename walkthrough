#!/bin/bash

# Step 1: Check Java installed or not
if java -version 2>&1 | grep -q "21"; then
  echo "Java 21 already installed - Skipping"
else
  echo "Installing Java 21..."
  sudo apt update -y
  sudo apt install openjdk-21-jdk -y
fi
java -version

# Step 2: Install Tomcat 10 directly
sudo apt update -y
sudo apt install tomcat10 tomcat10-admin -y

# Step 3: Change port from 8080 to 9000
sudo sed -i 's/port="8080"/port="9000"/' /etc/tomcat10/server.xml

# Step 4: Add Tomcat Users
sudo tee /etc/tomcat10/tomcat-users.xml > /dev/null << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<tomcat-users>
  <role rolename="manager-gui"/>
  <role rolename="manager-script"/>
  <role rolename="manager-jmx"/>
  <role rolename="manager-status"/>
  <user username="admin"    password="admin"    roles="manager-gui,manager-script,manager-jmx,manager-status"/>
  <user username="deployer" password="deployer" roles="manager-script"/>
  <user username="tomcat"   password="s3cret"   roles="manager-gui"/>
</tomcat-users>
EOF

# Step 5: Start Tomcat
sudo systemctl enable tomcat10
sudo systemctl restart tomcat10

echo "=========================================="
echo " Tomcat Started!"
echo " URL     : http://$(curl -s ifconfig.me):9000"
echo " Manager : http://$(curl -s ifconfig.me):9000/manager"
echo " User    : admin / admin"
echo "=========================================="


